# release-inputs.env — pinned build inputs for ISO tag-triggered releases
#
# This file is sourced by the build-iso-release workflow when a release tag
# (e.g. iso-v1.0.3) is pushed to this repository.  Update the values below
# before pushing the tag so the workflow picks up the correct rootfs version.
#
# These values are ONLY used for tag-push-triggered builds.  When the workflow
# is started via workflow_dispatch or repository_dispatch the caller-supplied
# inputs take precedence and this file is not consulted.
#
# ISO releases are independent of component (core/ui/rootfs) version tags.
# A single core or rootfs update does NOT require a new ISO release — the
# manifest-driven update system handles runtime component updates on installed
# systems without any ISO rebuild.

# Rootfs release tag to embed in the ISO (e.g. v2.1.0).
# Leave blank to auto-resolve the latest stable release from ROOTFS_REPO.
# Set explicitly when you want a deterministic pinned rootfs baseline.
ROOTFS_REF=

# Source repository for the rootfs release artifact.
# Override only if you host rootfs artifacts in a fork or mirror.
ROOTFS_REPO=daygle/dayshield-rootfs

# Installer UI ref (tag, branch, or SHA) to embed in the ISO.
# Leave blank to auto-resolve the latest stable installer UI release tag.
# If no stable release is available, the workflow falls back to main.
INSTALLER_UI_REF=
